from __future__ import annotations

import matplotlib.pyplot as plt
import pandas as pd
import seaborn as sns

PALETTE = __PALETTE__
TITLE = __TITLE__
X_LABEL = __X_LABEL__
Y_LABEL = __Y_LABEL__
ROW_COL = __ROW_COL__
COLUMN_COL = __COLUMN_COL__
VALUE_COL = __VALUE_COL__


def build_figure(df: pd.DataFrame):
    data = df.copy()
    matrix = data.pivot_table(index=ROW_COL, columns=COLUMN_COL, values=VALUE_COL, aggfunc="mean")
    cmap = sns.blend_palette(PALETTE, as_cmap=True)
    fig, ax = plt.subplots(figsize=(8, 6), dpi=150)
    sns.heatmap(matrix, cmap=cmap, annot=True, fmt=".2f", linewidths=0.5, cbar_kws={"shrink": 0.8}, ax=ax)
    ax.set_title(TITLE, fontsize=15)
    ax.set_xlabel(X_LABEL, fontsize=12)
    ax.set_ylabel(Y_LABEL, fontsize=12)
    fig.tight_layout()
    return fig
